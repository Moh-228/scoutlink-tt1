DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/scoutlink_tt?schema=public"
AUTH_SECRET="generate-a-random-secret-at-least-32-chars"

# Base URL de la aplicación (sin barra al final)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Gmail API (recuperación de cuenta) ──────────────────────────
# 1. Ve a https://console.cloud.google.com/ y crea/selecciona un proyecto.
# 2. Habilita la Gmail API en "APIs y servicios > Biblioteca".
# 3. Crea credenciales OAuth 2.0 tipo "Aplicación web".
#    - URI de redireccionamiento autorizado: https://developers.google.com/oauthplayground
# 4. Ve a https://developers.google.com/oauthplayground
#    - Icono de config > "Use your own OAuth credentials" > pega Client ID y Client Secret.
#    - En "Step 1" selecciona y autoriza el scope: https://mail.google.com/
#    - En "Step 2" haz clic en "Exchange authorization code for tokens" y copia el Refresh token.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Dirección Gmail desde la que se enviarán los correos (debe ser la cuenta que autorizaste)
GMAIL_SENDER_EMAIL=
